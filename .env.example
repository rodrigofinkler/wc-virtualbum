# ── Production database (Neon) ──────────────────────────────────────────────
# Get this from your Neon project → Connection Details → connection string
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Django ──────────────────────────────────────────────────────────────────
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-abc123...
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.vercel.app

# ── Local development (when running outside Docker) ─────────────────────────
# Copy this file to .env, fill in your Neon credentials, then:
#   cd backend && python manage.py runserver
# On Vercel, set these same vars in the dashboard (Settings → Environment Variables).
# Docker Compose local dev does NOT need this file — vars are in docker-compose.yml.
