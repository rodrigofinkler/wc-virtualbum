{
  "builds": [
    {
      "src": "vercel_wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "vercel_wsgi.py" },
    {
      "src": "(?!/frontend/)/(.*\\.(?:js|css|json|png|gif|svg|ico|woff2?|ttf|eot))",
      "dest": "frontend/$1"
    },
    { "src": "(?!/frontend/)/(.*)", "dest": "frontend/index.html" }
  ]
}
